-    __m128i MSG0 = _mm_shuffle_epi8(_mm_loadu_si128((const __m128i*)(block +  0)), MASK);
-    __m128i MSG1 = _mm_shuffle_epi8(_mm_loadu_si128((const __m128i*)(block + 16)), MASK);
