-        MSG = _mm_add_epi32(m0, _mm_load_si128((const __m128i*)&K[i])); \
-        STATE1 = _mm_sha256rnds2_epu32(STATE1, STATE0, MSG); \
-        TMP2 = _mm_alignr_epi8(m0, m3, 4); \
-        m1 = _mm_add_epi32(m1, TMP2); \
